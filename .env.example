# Bridge — copy to .env and fill in.
# One LLM provider key + one database file. That is the whole setup.

# OpenRouter (OpenAI-compatible). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Vision-capable, structured-JSON model. Default is FREE (Apache-2.0, no training
# on your inputs), which fits an education app's privacy posture. If the free tier
# is rate-limited, swap in the paid fallback below (still very cheap).
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# Paid fallback: OPENROUTER_MODEL=google/gemini-3.1-flash-lite  (~$0.25/$1.50 per MTok)
OPENROUTER_FALLBACK_MODEL=google/gemini-3.1-flash-lite

# SQLite — one file, zero setup.
DATABASE_URL="file:./dev.db"

# Serve cached AI responses so the full flow works with no key / no API burn.
# Set to false once OPENROUTER_API_KEY is real.
DEMO_MODE=true
