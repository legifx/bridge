# Bridge — copy to .env and fill in.

# OpenRouter (OpenAI-compatible). Required for live AI (capture, bridges, quizzes).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Vision-capable, structured-JSON model. Default is FREE (Apache-2.0, no training
# on your inputs). The fallback catches free-tier rate limits automatically.
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_FALLBACK_MODEL=google/gemini-3.1-flash-lite

# SQLite — one file, zero setup.
DATABASE_URL="file:./dev.db"

# --- Public demo hosting (optional) -----------------------------------------
# On Vercel the app enters public-demo mode automatically: username sign-in is
# open, and each profile gets a small AI budget (default 10 units).
# PUBLIC_DEMO=true            # force public-demo mode elsewhere
# DEMO_AI_QUOTA=10            # AI units per profile (extract=2, bridge/quiz/answer=1)
# Persistent hosted DB (Turso, SQLite-compatible) — recommended for the demo:
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=...
OPENROUTER_CAPTURE_MODEL=qwen/qwen3-vl-32b-instruct

# Owner unlock: sign in with this code to give an account unlimited AI budget
OWNER_UNLOCK_CODE=

# Session cookie signing — any long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Optional locally; set it on any hosted deployment so session cookies are
# HMAC-signed instead of being a bare (forgeable) learner id.
AUTH_SECRET=
