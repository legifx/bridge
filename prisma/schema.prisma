// Bridge — data model (see BUILD_PROMPT §4).
// SQLite, one file, zero setup. Embeddings are stored as raw Float32 bytes.
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Learner {
  id           String   @id @default(cuid())
  displayName  String
  handle       String?  @unique // normalized sign-in name (public demo: any name is open)
  passwordHash   String? // optional account lock (scrypt); null = open profile (legacy/seed)
  unlimited      Boolean   @default(false) // owner accounts: no AI quota (set via OWNER_UNLOCK_CODE)
  failedAttempts Int       @default(0) // consecutive wrong-password sign-ins (brute-force lockout)
  lockedUntil    DateTime? // sign-in blocked until this time after too many failures
  readingLevel Int      @default(3) // 1..5
  language     String   @default("en") // main language for learner-facing AI text (set at onboarding, editable later)
  aiUnits      Int      @default(0) // AI-call units used (quota enforced on public demo only)
  createdAt    DateTime @default(now())

  domains    InterestDomain[]
  sources    Source[]
  concepts   Concept[]
  brainItems BrainItem[]
  interviews OnboardingSession[]
}

// One adaptive onboarding interview. The full state (candidate domains, served
// questions, word-magnet tiers, picks) lives in `state`; every interaction the
// server sent and every answer it got is appended to `log` — the profile's
// provenance is inspectable, in the same spirit as the bridge verification log.
model OnboardingSession {
  id        String   @id @default(cuid())
  learnerId String
  status    String   @default("active") // active | done
  phase     String   @default("drill") // drill | verify | mirror | done
  state     String   @default("{}") // JSON InterviewState (tiers/decoys stay server-side)
  log       String   @default("[]") // JSON array of served interactions + answers
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  learner Learner @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@index([learnerId])
}

// The learner's second brain: a per-learner vector store that grows with every
// signal (onboarding picks, free-text interests, "that clicked" feedback).
// Near-duplicate signals strengthen an existing item's weight instead of
// inserting — this is how interest detection matures over time.
model BrainItem {
  id        String   @id @default(cuid())
  learnerId String
  kind      String // interest | anchor | signal
  label     String
  text      String // the text that was embedded
  embedding Bytes // Float32 vector (local all-MiniLM-L6-v2)
  weight    Float    @default(1)
  sourceRef String? // e.g. domainId / bridgeId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  learner Learner @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@index([learnerId])
}

model InterestDomain {
  id         String  @id @default(cuid())
  learnerId  String
  name       String
  embedding  Bytes // Float32 vector (local all-MiniLM-L6-v2)
  anchors    String  @default("[]") // JSON: concrete nouns from the learner's world
  alpha      Float   @default(1) // Beta posterior — successes + 1
  beta       Float   @default(1) // Beta posterior — failures + 1
  confidence Float   @default(0.5)
  depth      String  @default("hobbyist") // novice | hobbyist | deep — vocabulary tier verified at onboarding

  learner Learner  @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  bridges Bridge[]

  @@index([learnerId])
}

model Source {
  id        String   @id @default(cuid())
  learnerId String
  title     String? // folder name, derived from the material at capture time
  subject   String? // broad parent topic ("Überordner"), e.g. Chemistry — groups folders on the map
  kind      String // photo | pdf | text
  rawText   String
  imagePath String?
  createdAt DateTime @default(now())

  learner  Learner   @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  concepts Concept[]

  @@index([learnerId])
}

model Concept {
  id         String  @id @default(cuid())
  learnerId  String
  label      String
  definition String
  sourceQuote String
  difficulty Int     @default(3) // 1..5
  elo        Float   @default(1200) // mastery: learner ability per concept
  reviewEnabled Boolean @default(false) // opt-in spaced repetition (SM-2)
  embedding  Bytes? // stored for Stage-3 interest<->concept matching
  sourceId   String?

  learner  Learner  @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  source   Source?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  bridges  Bridge[]
  reviews  Review[]

  // prerequisite DAG edges
  edgesOut ConceptEdge[] @relation("fromConcept")
  edgesIn  ConceptEdge[] @relation("toConcept")

  @@index([learnerId])
}

model ConceptEdge {
  fromConceptId String
  toConceptId   String

  from Concept @relation("fromConcept", fields: [fromConceptId], references: [id], onDelete: Cascade)
  to   Concept @relation("toConcept", fields: [toConceptId], references: [id], onDelete: Cascade)

  @@id([fromConceptId, toConceptId])
}

model Bridge {
  id          String @id @default(cuid())
  conceptId   String
  domainId    String
  body        String
  status      String // accepted | rejected
  attempt     Int    @default(1)
  verdictJson String // full Verdict from the verifier
  createdAt   DateTime @default(now())

  concept  Concept        @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  domain   InterestDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  feedback Feedback[]

  @@index([conceptId])
}

model Review {
  id         String   @id @default(cuid())
  conceptId  String
  correct    Boolean
  answeredAt DateTime @default(now())
  nextDueAt  DateTime
  easeFactor Float    @default(2.5)
  interval   Int      @default(0) // days
  detailJson String?  // JSON snapshot of the check: mastery, free/mcq correctness, per-problem results

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([conceptId])
}

model Feedback {
  id        String   @id @default(cuid())
  bridgeId  String
  clicked   Boolean // true = "that clicked", false = "didn't land"
  createdAt DateTime @default(now())

  bridge Bridge @relation(fields: [bridgeId], references: [id], onDelete: Cascade)
}

// Aggregate only — no learner ids, no names, no interest data (see §7).
model ClassSnapshot {
  id            String @id @default(cuid())
  cohortKey     String
  conceptLabel  String
  attempts      Int    @default(0)
  masteredCount Int    @default(0)

  @@index([cohortKey])
}
